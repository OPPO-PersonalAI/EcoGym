# Model Token Pricing Configuration (Unit: USD per million tokens)
# 
# Note: This file uses pricing from third-party API providers. 
# If you're using official APIs (OpenAI, Anthropic, etc.), please update the pricing accordingly.
# You can also add your own models with custom pricing.

token_pricing:
  "gemini-3-pro-preview":
    input: 2.00
    output: 12.00
    supplier: openai
  "text-embedding-3-small":
    input: 0.02
    output: 0.00

